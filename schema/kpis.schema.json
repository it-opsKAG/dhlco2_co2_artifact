{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dhlco2.local/schema/kpis.schema.json",
  "title": "DHLCO2 KPI Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kpis"
  ],
  "properties": {
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "phase",
          "name",
          "description",
          "formula",
          "unit",
          "functional_unit",
          "lifecycle_steps",
          "emission_type",
          "data_sources",
          "authoritative_system",
          "provisional_owner",
          "measurement_mode",
          "granularity",
          "proxy_refs",
          "gap_refs",
          "iso_refs",
          "source_refs",
          "status",
          "unknowns"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(BLD|RUN)-[0-9]{3}$"
          },
          "phase": {
            "type": "string",
            "enum": [
              "build",
              "run"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "formula": {
            "type": "string",
            "minLength": 1
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "functional_unit": {
            "type": "string",
            "minLength": 1
          },
          "lifecycle_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "Plan",
                "Code",
                "Build",
                "Test",
                "Release",
                "Deploy",
                "Operate",
                "Monitor"
              ]
            }
          },
          "emission_type": {
            "type": "string",
            "enum": [
              "direct",
              "indirect",
              "mixed"
            ]
          },
          "data_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "authoritative_system": {
            "type": "string",
            "minLength": 1
          },
          "provisional_owner": {
            "type": "string",
            "minLength": 1
          },
          "measurement_mode": {
            "type": "string",
            "minLength": 1
          },
          "granularity": {
            "type": "string",
            "minLength": 1
          },
          "proxy_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^PRX-[0-9]{3}$"
            }
          },
          "gap_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^GAP-[0-9]{3}$"
            }
          },
          "iso_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate"
            ]
          },
          "unknowns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
